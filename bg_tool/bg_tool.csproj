<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net472</TargetFramework>
    <PlatformTarget>x86</PlatformTarget>
    <RootNamespace>BgTool</RootNamespace>
    <AssemblyName>bg_tool</AssemblyName>
    <LangVersion>8.0</LangVersion>
    <Version>0.5.7</Version>
    <Description>炉石酒馆战棋联赛工具（WinForms 版）</Description>
    <ApplicationIcon>icon.ico</ApplicationIcon>
  </PropertyGroup>

  <!-- HDT 引用 -->
  <ItemGroup>
    <Reference Include="HearthMirror">
      <HintPath>$(HDT_PATH)\HearthMirror.dll</HintPath>
      <Private>True</Private>
    </Reference>

    <Reference Include="System.Net.Http">
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Web.Extensions">
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Windows.Forms">
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Drawing">
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="bg_heroes.json" />
  </ItemGroup>

  <!-- VC++ Runtime（untapped-scry-dotnet.dll 依赖，打包避免用户缺 VC++ 运行时） -->
  <ItemGroup>
    <Content Include="$(SystemRoot)\SysWOW64\vcruntime140.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="$(SystemRoot)\SysWOW64\vcruntime140_1.dll" Condition="Exists('$(SystemRoot)\SysWOW64\vcruntime140_1.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="$(SystemRoot)\SysWOW64\msvcp140.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Content Include="icon.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="config.json.example">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
