<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <RuntimeIdentifier>win-x86</RuntimeIdentifier>
    <PublishSingleFile>false</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <PublishTrimmed>true</PublishTrimmed>
    <LangVersion>12.0</LangVersion>
    <RootNamespace>BgTool</RootNamespace>
    <AssemblyName>bg_tool</AssemblyName>
    <Version>0.2.0</Version>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- HearthMirror + HearthDb：从 HDT 目录或本地拷贝 -->
  <ItemGroup>
    <Reference Include="HearthMirror" Condition="Exists('$(HDT_PATH)\HearthMirror.dll')">
      <HintPath>$(HDT_PATH)\HearthMirror.dll</HintPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Reference>
    <Reference Include="HearthDb" Condition="Exists('$(HDT_PATH)\HearthDb.dll')">
      <HintPath>$(HDT_PATH)\HearthDb.dll</HintPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Reference>
    <!-- 兜底：本地 dll -->
    <Reference Include="HearthMirror" Condition="Exists('HearthMirror.dll') And !Exists('$(HDT_PATH)\HearthMirror.dll')">
      <HintPath>HearthMirror.dll</HintPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Reference>
    <Reference Include="HearthDb" Condition="Exists('HearthDb.dll') And !Exists('$(HDT_PATH)\HearthDb.dll')">
      <HintPath>HearthDb.dll</HintPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Reference>
  </ItemGroup>

</Project>
