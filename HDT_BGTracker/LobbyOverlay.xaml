<UserControl x:Class="HDT_BGTracker.LobbyOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBlock x:Name="LobbyText"
                   Text=""
                   Foreground="#FFE8E3E3"
                   Background="#CC272424"
                   FontSize="18"
                   FontFamily="Consolas"
                   Padding="8,4"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   MouseLeftButtonDown="LobbyText_MouseLeftButtonDown"
                   MouseLeftButtonUp="LobbyText_MouseLeftButtonUp"
                   MouseMove="LobbyText_MouseMove"/>
    </Grid>
</UserControl>
